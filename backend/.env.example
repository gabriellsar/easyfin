DJANGO_SECRET_KEY=troque-em-producao
DJANGO_DEBUG=1

# DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
# CORS_ALLOWED_ORIGINS=http://localhost:5173
# DATABASE_URL=postgresql://usuario:senha@host:5432/easyfin

POSTGRES_DB=easyfin
POSTGRES_USER=easyfin
POSTGRES_PASSWORD=easyfin
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Fonte de cotações: "real" (brapi + Banco Central) ou "mock" (simulada)
MARKET_DATA_PROVIDER=real

# https://brapi.dev — cotações e histórico de ações/FIIs funcionam sem token;
# o índice Ibovespa (^BVSP) EXIGE um token (gratuito após cadastro).
BRAPI_TOKEN=
